{
  "name": "@wello-code/desktop",
  "version": "0.1.2",
  "private": true,
  "license": "Apache-2.0",
  "author": "Wello",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wello-code/wello-code.git"
  },
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json --composite false && tsc --noEmit -p tsconfig.web.json --composite false",
    "test:e2e": "playwright test",
    "package:win": "electron-vite build && node scripts/package-win.mjs",
    "dist:win": "pnpm package:win && electron-builder --win --prepackaged release/WelloCode-win-x64"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.207",
    "@wello-code/agent-core": "workspace:*",
    "@wello-code/agent-sdk": "workspace:*",
    "@wello-code/contracts": "workspace:*",
    "@wello-code/design-system": "workspace:*",
    "electron-updater": "^6.8.9",
    "highlight.js": "^11.11.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "rcedit": "^5.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^5.4.11"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk-darwin-arm64": "0.3.207"
  }
}
