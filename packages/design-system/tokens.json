{
  "$description": "Workbench UI v1.1 semantic token contract. Primitive values are intentionally not consumed by components.",
  "color": {
    "canvas": { "$type": "color", "$value": "#151515" },
    "surface": {
      "0": { "$type": "color", "$value": "#1A1A1A" },
      "1": { "$type": "color", "$value": "#202020" },
      "2": { "$type": "color", "$value": "#292929" },
      "3": { "$type": "color", "$value": "#323232" }
    },
    "text": {
      "primary": { "$type": "color", "$value": "#F4F4F4" },
      "secondary": { "$type": "color", "$value": "#B4B4B4" },
      "muted": { "$type": "color", "$value": "#797979" }
    },
    "feedback": {
      "success": { "$type": "color", "$value": "#78C596" },
      "warning": { "$type": "color", "$value": "#E5B66E" },
      "danger": { "$type": "color", "$value": "#ED8D8D" },
      "info": { "$type": "color", "$value": "#8AB9E8" }
    }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "6": { "$type": "dimension", "$value": "24px" },
    "8": { "$type": "dimension", "$value": "32px" }
  },
  "radius": {
    "control": { "$type": "dimension", "$value": "6px" },
    "panel": { "$type": "dimension", "$value": "10px" },
    "large": { "$type": "dimension", "$value": "14px" }
  },
  "size": {
    "control": { "$type": "dimension", "$value": "32px" },
    "titlebar": { "$type": "dimension", "$value": "36px" },
    "sidebar": { "$type": "dimension", "$value": "256px" }
  },
  "primitive": {
    "gray": {
      "0": { "$type": "color", "$value": "#FFFFFF" },
      "50": { "$type": "color", "$value": "#F4F4F4" },
      "100": { "$type": "color", "$value": "#E8E8E8" },
      "300": { "$type": "color", "$value": "#B4B4B4" },
      "500": { "$type": "color", "$value": "#797979" },
      "600": { "$type": "color", "$value": "#575757" },
      "700": { "$type": "color", "$value": "#3A3A3A" },
      "750": { "$type": "color", "$value": "#323232" },
      "800": { "$type": "color", "$value": "#292929" },
      "850": { "$type": "color", "$value": "#202020" },
      "900": { "$type": "color", "$value": "#1A1A1A" },
      "950": { "$type": "color", "$value": "#151515" }
    },
    "blue": {
      "300": { "$type": "color", "$value": "#A6C8FF" },
      "400": { "$type": "color", "$value": "#8AB9E8" }
    },
    "green": { "400": { "$type": "color", "$value": "#78C596" } },
    "amber": { "400": { "$type": "color", "$value": "#E5B66E" } },
    "red": { "400": { "$type": "color", "$value": "#ED8D8D" } }
  },
  "semantic": {
    "$description": "Components consume this layer, never primitive colors.",
    "surface": {
      "canvas": { "$type": "color", "$value": "{color.canvas}" },
      "base": { "$type": "color", "$value": "{color.surface.0}" },
      "panel": { "$type": "color", "$value": "{color.surface.1}" },
      "raised": { "$type": "color", "$value": "{color.surface.2}" },
      "selected": { "$type": "color", "$value": "{color.surface.3}" },
      "overlay": { "$type": "color", "$value": "#262626" },
      "scrim": { "$type": "color", "$value": "#00000099" }
    },
    "icon": {
      "default": { "$type": "color", "$value": "{color.text.primary}" },
      "secondary": { "$type": "color", "$value": "{color.text.secondary}" },
      "muted": { "$type": "color", "$value": "{color.text.muted}" },
      "disabled": { "$type": "color", "$value": "#79797999" }
    },
    "border": {
      "subtle": { "$type": "color", "$value": "#2C2C2C" },
      "default": { "$type": "color", "$value": "#3A3A3A" },
      "strong": { "$type": "color", "$value": "#575757" },
      "focus": { "$type": "color", "$value": "#A6C8FF" }
    },
    "editor": {
      "selection": { "$type": "color", "$value": "#3B4F6B" },
      "lineHighlight": { "$type": "color", "$value": "#FFFFFF0D" },
      "gutter": { "$type": "color", "$value": "#777777" }
    },
    "diff": {
      "added": {
        "background": { "$type": "color", "$value": "#1C3A2A" },
        "border": { "$type": "color", "$value": "#4F9B70" },
        "text": { "$type": "color", "$value": "#A7E0B7" }
      },
      "removed": {
        "background": { "$type": "color", "$value": "#422525" },
        "border": { "$type": "color", "$value": "#B86666" },
        "text": { "$type": "color", "$value": "#F0B3B3" }
      },
      "modified": {
        "background": { "$type": "color", "$value": "#3D341E" },
        "border": { "$type": "color", "$value": "#B99A48" },
        "text": { "$type": "color", "$value": "#EBD493" }
      }
    },
    "git": {
      "added": { "$type": "color", "$value": "#78C596" },
      "modified": { "$type": "color", "$value": "#E5B66E" },
      "deleted": { "$type": "color", "$value": "#ED8D8D" },
      "conflict": { "$type": "color", "$value": "#D89863" }
    },
    "agent": {
      "running": { "$type": "color", "$value": "#8AB9E8" },
      "awaitingPermission": { "$type": "color", "$value": "#E5B66E" },
      "complete": { "$type": "color", "$value": "#78C596" },
      "error": { "$type": "color", "$value": "#ED8D8D" }
    },
    "permission": {
      "safe": { "$type": "color", "$value": "#78C596" },
      "warning": { "$type": "color", "$value": "#E5B66E" },
      "danger": { "$type": "color", "$value": "#ED8D8D" }
    }
  },
  "typography": {
    "fontFamily": {
      "ui": { "$type": "fontFamily", "$value": "Inter, ui-sans-serif, system-ui, sans-serif" },
      "code": { "$type": "fontFamily", "$value": "SFMono-Regular, Consolas, Liberation Mono, monospace" }
    },
    "fontSize": {
      "meta": { "$type": "dimension", "$value": "11px" },
      "ui": { "$type": "dimension", "$value": "13px" },
      "body": { "$type": "dimension", "$value": "15px" },
      "section": { "$type": "dimension", "$value": "20px" },
      "display": { "$type": "dimension", "$value": "32px" }
    },
    "lineHeight": {
      "tight": { "$type": "number", "$value": 1.15 },
      "ui": { "$type": "number", "$value": 1.45 },
      "code": { "$type": "number", "$value": 1.85 }
    },
    "fontWeight": {
      "regular": { "$type": "number", "$value": 400 },
      "medium": { "$type": "number", "$value": 560 },
      "semibold": { "$type": "number", "$value": 650 },
      "bold": { "$type": "number", "$value": 700 }
    }
  },
  "borderWidth": {
    "default": { "$type": "dimension", "$value": "1px" },
    "focus": { "$type": "dimension", "$value": "2px" }
  },
  "opacity": {
    "disabled": { "$type": "number", "$value": 0.42 },
    "scrim": { "$type": "number", "$value": 0.6 }
  },
  "elevation": {
    "menu": { "$type": "shadow", "$value": "0 8px 24px rgb(0 0 0 / .28)" },
    "popover": { "$type": "shadow", "$value": "0 12px 32px rgb(0 0 0 / .32)" },
    "dialog": { "$type": "shadow", "$value": "0 18px 48px rgb(0 0 0 / .38)" },
    "commandPalette": { "$type": "shadow", "$value": "0 20px 56px rgb(0 0 0 / .42)" }
  },
  "zIndex": {
    "base": { "$type": "number", "$value": 0 },
    "panel": { "$type": "number", "$value": 10 },
    "sticky": { "$type": "number", "$value": 20 },
    "overlay": { "$type": "number", "$value": 30 },
    "modal": { "$type": "number", "$value": 40 },
    "toast": { "$type": "number", "$value": 50 }
  },
  "layout": {
    "window": {
      "minWidth": { "$type": "dimension", "$value": "900px" },
      "minHeight": { "$type": "dimension", "$value": "600px" }
    },
    "pane": {
      "activityRail": { "$type": "dimension", "$value": "48px" },
      "sidebarMin": { "$type": "dimension", "$value": "220px" },
      "sidebarMax": { "$type": "dimension", "$value": "360px" },
      "inspectorMin": { "$type": "dimension", "$value": "280px" },
      "inspectorMax": { "$type": "dimension", "$value": "480px" },
      "editorMin": { "$type": "dimension", "$value": "480px" },
      "bottomMin": { "$type": "dimension", "$value": "160px" }
    },
    "composer": {
      "minHeight": { "$type": "dimension", "$value": "64px" },
      "maxHeight": { "$type": "dimension", "$value": "240px" }
    }
  },
  "motion": {
    "duration": {
      "instant": { "$type": "duration", "$value": "0ms" },
      "press": { "$type": "duration", "$value": "80ms" },
      "hover": { "$type": "duration", "$value": "120ms" },
      "standard": { "$type": "duration", "$value": "160ms" },
      "overlay": { "$type": "duration", "$value": "180ms" },
      "panel": { "$type": "duration", "$value": "220ms" }
    },
    "easing": {
      "standard": { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1] },
      "exit": { "$type": "cubicBezier", "$value": [0.4, 0, 1, 1] }
    },
    "distance": {
      "overlay": { "$type": "dimension", "$value": "4px" },
      "panel": { "$type": "dimension", "$value": "12px" }
    }
  }
}
